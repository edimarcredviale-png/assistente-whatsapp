# ============================================
# VARIÁVEIS DE AMBIENTE - ASSISTENTE WHATSAPP
# ============================================

# 🔑 CHAVES DE API
ANTHROPIC_API_KEY=sk-ant-sua-chave-aqui
OPENAI_API_KEY=sk-sua-chave-openai-aqui

# 🌐 SERVIDOR
PORT=8080

# 🗄️ BANCO DE DADOS (PostgreSQL)
# Para Railway: será preenchido automaticamente
# Para local: postgresql://usuario:senha@localhost:5432/assistente
DATABASE_URL=postgresql://usuario:senha@localhost:5432/assistente

# 📱 TWILIO (opcional, se usar Twilio)
TWILIO_ACCOUNT_SID=seu_account_sid
TWILIO_AUTH_TOKEN=seu_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+55xxxxxxxxxxxx

# 🔐 SEGURANÇA
NODE_ENV=production
